# Agent Security Gateway environment example.
# Copy to .env for local shell usage if needed. Do not commit real secrets.

ASG_RUNTIME_DIR="$HOME/.agent-security-gateway"
ASG_CONFIG="$HOME/.agent-security-gateway/config.json"
ASG_PYTHON="python3"

# Convenience variable for curl tests. The gateway itself does not read this.
ASG_AGENT_TOKEN="paste-caller-token-for-curl-tests"
HUMAN_OPERATOR_TOKEN="paste-human-operator-token-for-approval-curl-tests"

# Backend credentials are looked up by route.backend.api_key_env only.
# Caller Authorization tokens must never be reused as backend credentials.
PI1_AGENT_BACKEND_KEY=""
UBUNTU1_STAGING_BACKEND_KEY=""
UBUNTU1_KB_BACKEND_KEY=""
UBUNTU2_AGENT_BACKEND_KEY=""
WINDOWS_IMAGE_BACKEND_KEY=""
RTX3090_BACKEND_KEY=""
ASG_BACKEND_HMAC_KEY=""

# .env is intentionally ignored by git. Never commit real tokens or API keys.
