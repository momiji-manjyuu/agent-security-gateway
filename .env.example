# Agent Security Proxy environment example.
# Copy to .env for local shell usage if needed. Do not put real secrets in this file.

# Runtime directory used by scripts/install-launch-agent.sh when rendering service files.
ASP_RUNTIME_DIR=/Users/example/.agent-security-proxy

# Config path used by scripts/start.sh and scripts/status.sh.
ASP_CONFIG=/Users/example/.agent-security-proxy/config.json

# Python interpreter used by scripts/start.sh, scripts/status.sh, and install-launch-agent.sh.
ASP_PYTHON=/usr/bin/python3

# Optional backend HTTP API key. Leave empty when the backend is unauthenticated or loopback-only.
BACKEND_AGENT_API_KEY=

# Convenience variable for README curl examples. The proxy itself does not read this.
ASP_AGENT_TOKEN=
