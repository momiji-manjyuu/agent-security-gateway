{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-security-gateway/reviewed_summary.schema.json",
  "title": "Agent Security Gateway reviewed artifact summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claims",
    "source",
    "injection_flags",
    "confidence"
  ],
  "properties": {
    "claims": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "content_sha256",
        "derived_from"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^art_[a-f0-9]{32}$"
        },
        "content_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "derived_from": {
          "type": "string",
          "pattern": "^art_[a-f0-9]{32}$"
        }
      }
    },
    "injection_flags": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
