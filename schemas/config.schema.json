{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-security-gateway/config.schema.json",
  "title": "Agent Security Gateway config",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "bind",
    "port",
    "agents",
    "routes"
  ],
  "properties": {
    "bind": {
      "type": "string",
      "default": "127.0.0.1"
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "default": 8788
    },
    "max_body_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "kill_switch_file": {
      "type": "string"
    },
    "audit_log": {
      "type": "string"
    },
    "require_known_run_id": {
      "type": "boolean"
    },
    "artifact_store": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string"
        },
        "max_artifact_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1,
          "default": 90
        }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/agent"
      }
    },
    "routes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/route"
      }
    },
    "runs": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/run_scope"
      }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": [
        "token_sha256",
        "allowed_capabilities",
        "allowed_routes"
      ],
      "additionalProperties": true,
      "properties": {
        "token_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "trust_tier": {
          "type": "string"
        },
        "allowed_client_cidrs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_routes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "route": {
      "type": "object",
      "required": [
        "kind",
        "allowed_callers",
        "required_capability"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "enum": [
            "inspect_only",
            "openai_chat_completions",
            "http_json",
            "command",
            "artifact_review"
          ]
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_capability": {
          "type": "string"
        },
        "backend": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "require_signature": {
              "type": "boolean",
              "default": false
            },
            "max_review_chars": {
              "type": "integer",
              "minimum": 1,
              "default": 40000
            }
          }
        },
        "input_policy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "accepted_taint": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allow_missing_taint": {
              "type": "boolean"
            },
            "require_message_type": {
              "type": "string"
            },
            "require_structured_task": {
              "type": "boolean"
            },
            "require_x_research_request": {
              "type": "boolean"
            },
            "max_x_query_chars": {
              "type": "integer",
              "minimum": 1
            },
            "max_x_question_chars": {
              "type": "integer",
              "minimum": 1
            },
            "max_x_results": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "allow_raw_external_content": {
              "type": "boolean"
            },
            "disallow_external_urls": {
              "type": "boolean"
            },
            "max_messages": {
              "type": "integer",
              "minimum": 0
            },
            "max_batch_size": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "action_policy": {
          "type": "object"
        },
        "artifact_policy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowed_statuses": {
              "type": "array",
              "items": {
                "enum": [
                  "unchecked",
                  "verified",
                  "needs_review",
                  "blocked"
                ]
              }
            },
            "max_artifact_bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "report_policy": {
          "type": "object",
          "properties": {
            "forward_audit_receipt": {
              "type": "boolean"
            },
            "return_audit_receipt": {
              "type": "boolean"
            },
            "include_structured_extract": {
              "type": "boolean"
            },
            "notify_on_block": {
              "type": "boolean"
            },
            "max_receipts_per_minute": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "output_policy": {
          "type": "object"
        }
      }
    },
    "run_scope": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "allowed_routes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "denied_routes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expires_at": {
          "type": "string"
        }
      }
    }
  }
}
